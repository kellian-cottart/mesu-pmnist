{
  "network": "matrixvariatemlp",
  "network_params": {
    "layers": [784, 50, 10],
    "activation_fn": "relu"
  },
  "optimizer": "foovbmatrixvariate",
  "optimizer_params": {
    "lr_mu": 1,
    "lr_sigma": 1,
    "clamp_grad": 0
  },
  "task": "PermutedMNIST",
  "n_train_samples": 50,
  "n_test_samples": 50,
  "n_tasks": 25,
  "epochs": 10,
  "train_batch_size": 256,
  "test_batch_size": 256,
  "max_parallel_permutation": 100,
  "seed": 10222
}
