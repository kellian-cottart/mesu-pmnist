{
  "network": "matrixvariatemlp",
  "network_params": {
    "layers": [784, 50, 10],
    "activation_fn": "relu",
    "alpha": 0.5
  },
  "optimizer": "foovbmatrixvariate",
  "optimizer_params": {
    "lr_mu": 1,
    "lr_sigma": 1,
    "clamp_grad": 0
  },
  "task": "PermutedMNIST",
  "n_train_samples": 500,
  "n_test_samples": 500,
  "n_tasks": 10,
  "epochs": 20,
  "train_batch_size": 128,
  "test_batch_size": 1000,
  "max_parallel_permutation": 100,
  "seed": 1000
}
