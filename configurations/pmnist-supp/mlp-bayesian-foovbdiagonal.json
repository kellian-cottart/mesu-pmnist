{
  "network": "bayesianmlp",
  "network_params": {
    "layers": [784, 100, 100, 10],
    "activation_fn": "relu",
    "use_bias": true
  },
  "optimizer": "foovbdiagonal",
  "optimizer_params": {
    "lr_mu": 1,
    "lr_sigma": 1,
    "clamp_grad": 0
  },
  "task": "PermutedMNIST",
  "task_params": {
    "dataset_normalisation": "standardised"
  },
  "n_train_samples": 10,
  "n_test_samples": 10,
  "n_tasks": 10,
  "epochs": 20,
  "train_batch_size": 128,
  "test_batch_size": 1000,
  "max_parallel_permutation": 100,
  "seed": 1000
}
