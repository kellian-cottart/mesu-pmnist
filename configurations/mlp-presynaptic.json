{
  "network": "presynapticmlp",
  "network_params": {
    "layers": [784, 200, 200, 10],
    "activation_fn": "relu"
  },
  "optimizer": "presynaptic",
  "optimizer_params": {
    "lr": 0.005,
    "p_up": 0.05,
    "p_down": 0.05,
    "p_freeze": 0.9353,
    "p_max": 1.0,
    "p_min": 0.25,
    "g_lim": 0.001
  },
  "task": "PermutedMNIST",
  "n_tasks": 10,
  "epochs": 10,
  "train_batch_size": 100,
  "test_batch_size": 128,
  "max_parallel_permutation": 50,
  "seed": 1000
}
